{
  "name": "@hedge-rod/sdk",
  "version": "0.1.0",
  "description": "Typed TypeScript client for the HEDGE-ROD wash-trading detection API for the Stellar DEX.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stellar",
    "sdex",
    "wash-trading",
    "fraud-detection",
    "hedge-rod",
    "webhook",
    "hmac"
  ],
  "author": "HedgeRod contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/hedge-rod/hedge-rod-backend",
    "directory": "sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
